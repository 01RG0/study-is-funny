# Instapay Payment System - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Google Gemini Vision API Key
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Instapay API Configuration
# Get from: https://instapay.eg/developers
INSTAPAY_API_KEY=your_instapay_api_key_here
INSTAPAY_MERCHANT_ID=your_merchant_id_here

# MongoDB Configuration (Optional)
# Default: mongodb+srv://root:root@cluster0.vkskqhg.mongodb.net/attendance_system
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Server Configuration
SERVER_ENV=development
DEBUG_MODE=false

# Payment Configuration
PAYMENT_MIN_AMOUNT=50
PAYMENT_MAX_AMOUNT=1000
PAYMENT_CURRENCY=EGP
TRANSACTION_MAX_AGE_DAYS=7

# Admin Settings
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+20XXXXXXXXXX
